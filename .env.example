# Vereiste omgevingsvariabelen voor de Supabase-gebaseerde frontend

# Supabase project URL (te vinden in Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://jouw-project.supabase.co

# Supabase anonieme/publieke sleutel (te vinden in Supabase dashboard → Settings → API)
VITE_SUPABASE_ANON_KEY=jouw-anon-key

# Basis-pad van de app (gebruik / voor de meeste hosting-omgevingen)
BASE_PATH=/
