# Vereiste omgevingsvariabelen voor productie

# PostgreSQL verbindings-URL (automatisch ingevuld door Railway bij het toevoegen van een database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Poort waarop de server draait (automatisch ingevuld door Railway)
PORT=8080

# Geheime sleutel voor het ondertekenen van sessie-cookies (kies een lange, willekeurige string)
SESSION_SECRET=verander-dit-naar-een-geheime-sleutel

# Omgeving (altijd "production" op Railway)
NODE_ENV=production
